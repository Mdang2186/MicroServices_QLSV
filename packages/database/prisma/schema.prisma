generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. QUẢN LÝ NGƯỜI DÙNG & TÀI KHOẢN (IAM)
// ============================================================================
model User {
  id           String    @id @default(uuid()) @db.VarChar(50)
  username     String    @unique @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.NVarChar(255)
  // Các Role: SUPER_ADMIN, ACADEMIC_STAFF, LECTURER, STUDENT
  role         String    @default("STUDENT") @db.VarChar(50) 
  avatarUrl    String?
  phone        String?   @db.VarChar(20)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  
  lecturer     Lecturer?
  student      Student?
}

// ============================================================================
// 2. CƠ CẤU TỔ CHỨC & DANH MỤC ĐÀO TẠO
// ============================================================================
model Faculty {
  id        String     @id @default(uuid()) @db.VarChar(50)
  code      String     @unique @db.VarChar(50)
  name      String     @db.NVarChar(255)
  deanName  String?    @db.NVarChar(255)
  
  lecturers Lecturer[]
  majors    Major[]
}

model Major {
  id                   String       @id @default(uuid()) @db.VarChar(50)
  facultyId            String       @db.VarChar(50)
  code                 String       @unique @db.VarChar(50)
  name                 String       @db.NVarChar(255)
  totalCreditsRequired Int          @default(120)
  
  faculty              Faculty      @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminClasses         AdminClass[]
  students             Student[]
  subjects             Subject[]
}

model Subject {
  id              String         @id @default(uuid()) @db.VarChar(50)
  majorId         String         @db.VarChar(50)
  code            String         @unique @db.VarChar(50)
  name            String         @db.NVarChar(255)
  credits         Int
  theoryCredits   Int            @default(2)
  practiceCredits Int            @default(1)
  isMandatory     Boolean        @default(true)
  department      String?        @db.NVarChar(255)
  description     String?        @db.NVarChar(Max)
  
  major           Major          @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classes         CourseClass[]
  grades          Grade[]
  
  requiredFor     Prerequisite[] @relation("PrerequisiteFor")
  prerequisites   Prerequisite[] @relation("SubjectPrerequisites")
}

model Prerequisite {
  id             String  @id @default(uuid()) @db.VarChar(50)
  subjectId      String  @db.VarChar(50)
  prerequisiteId String  @db.VarChar(50)
  type           String  @db.VarChar(50) // Ví dụ: BẮT BUỘC, KHUYẾN NGHỊ
  
  prerequisite   Subject @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject        Subject @relation("SubjectPrerequisites", fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([subjectId, prerequisiteId])
}

// ============================================================================
// 3. HỒ SƠ SINH VIÊN, GIẢNG VIÊN & LỚP DANH NGHĨA
// ============================================================================
model Lecturer {
  id           String        @id @default(uuid()) @db.VarChar(50)
  userId       String        @unique @db.VarChar(50)
  facultyId    String?       @db.VarChar(50)
  lectureCode  String        @unique @db.VarChar(50)
  fullName     String        @db.NVarChar(255)
  degree       String?       @db.NVarChar(100)
  phone        String?       @db.VarChar(20)
  
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty      Faculty?      @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminClasses AdminClass[]
  classes      CourseClass[]
}

model AdminClass {
  id        String    @id @default(uuid()) @db.VarChar(50)
  majorId   String    @db.VarChar(50)
  code      String    @unique @db.VarChar(50)
  name      String    @db.NVarChar(255)
  cohort    String?   @db.VarChar(50)
  advisorId String?   @db.VarChar(50)
  
  major     Major     @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  advisor   Lecturer? @relation(fields: [advisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students  Student[]
}

model Student {
  id                 String       @id @default(uuid()) @db.VarChar(50)
  userId             String       @unique @db.VarChar(50)
  adminClassId       String?      @db.VarChar(50)
  majorId            String       @db.VarChar(50)
  studentCode        String       @unique @db.VarChar(50)
  fullName           String       @db.NVarChar(255)
  dob                DateTime
  gender             String?      @db.NVarChar(20)
  phone              String?      @db.VarChar(20)
  address            String?      @db.NVarChar(500)
  citizenId          String?      @db.VarChar(50)
  emailPersonal      String?      @db.VarChar(100)
  intake             String?      @db.VarChar(50)
  gpa                Float        @default(0.0)
  cpa                Float        @default(0.0)
  totalEarnedCredits Int          @default(0)
  // Các status: ACTIVE, RESERVED, DROPOUT, GRADUATED
  status             String       @default("ACTIVE") @db.VarChar(50) 
  
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  adminClass         AdminClass?  @relation(fields: [adminClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major              Major        @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  enrollments        Enrollment[]
  grades             Grade[]
  tuitionFees        TuitionFee[]
}

// ============================================================================
// 4. VẬN HÀNH ĐÀO TẠO & XẾP LỊCH
// ============================================================================
model Semester {
  id                String        @id @default(uuid()) @db.VarChar(50)
  code              String        @unique @db.VarChar(50)
  name              String        @db.NVarChar(255)
  year              Int           @default(2024)
  startDate         DateTime
  endDate           DateTime
  isCurrent         Boolean       @default(false)
  registerStartDate DateTime?
  registerEndDate   DateTime?
  
  classes           CourseClass[]
  tuitionFees       TuitionFee[]
}

model Room {
  id        String          @id @default(uuid()) @db.VarChar(50)
  name      String          @unique @db.VarChar(100)
  building  String?         @db.VarChar(100)
  capacity  Int             @default(50)
  // Các type: THEORY, PRACTICE
  type      String          @default("THEORY") @db.VarChar(50) 
  
  schedules ClassSchedule[]
}

model CourseClass {
  id                String          @id @default(uuid()) @db.VarChar(50)
  subjectId         String          @db.VarChar(50)
  semesterId        String          @db.VarChar(50)
  lecturerId        String?         @db.VarChar(50)
  code              String          @unique @db.VarChar(50)
  name              String          @db.NVarChar(255)
  adminClassCode    String?         @db.VarChar(50)
  tuitionMultiplier Float           @default(1.0)
  maxSlots          Int             @default(60)
  currentSlots      Int             @default(0)
  // Các status: OPEN, CLOSED, CANCELLED, LOCKED
  status            String          @default("OPEN") @db.VarChar(50) 
  
  subject           Subject         @relation(fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester          Semester        @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lecturer          Lecturer?       @relation(fields: [lecturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  schedules         ClassSchedule[]
  enrollments       Enrollment[]
  grades            Grade[]
}

model ClassSchedule {
  id            String      @id @default(uuid()) @db.VarChar(50)
  courseClassId String      @db.VarChar(50)
  roomId        String?     @db.VarChar(50)
  dayOfWeek     Int
  shift         Int
  type          String      @db.VarChar(50) // THEORY hoặc PRACTICE
  
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  room          Room?       @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Ràng buộc 1: Chống xếp trùng phòng học (1 phòng không thể có 2 lớp cùng ca cùng ngày)
  @@unique([roomId, dayOfWeek, shift])
}

// ============================================================================
// 5. ĐĂNG KÝ HỌC, ĐIỂM DANH & KẾT QUẢ
// ============================================================================
model Enrollment {
  id                String       @id @default(uuid()) @db.VarChar(50)
  studentId         String       @db.VarChar(50)
  courseClassId     String       @db.VarChar(50)
  status            String       @default("PENDING") @db.VarChar(50) // PENDING, SUCCESS, CANCELLED
  registeredAt      DateTime     @default(now())
  tuitionFee        Decimal      @db.Decimal(10, 2)
  isEligibleForExam Boolean      @default(true)
  banReason         String?      @db.NVarChar(255)
  
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  courseClass       CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  attendances       Attendance[]

  // Ràng buộc: Một sinh viên không thể đăng ký 2 lần vào 1 Lớp học phần
  @@unique([studentId, courseClassId])
}

model Attendance {
  id           String     @id @default(uuid()) @db.VarChar(50)
  enrollmentId String     @db.VarChar(50)
  date         DateTime   @db.Date
  status       String     @default("PRESENT") @db.VarChar(50) // PRESENT, ABSENT, EXCUSED
  note         String?    @db.NVarChar(255)
  
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // Ràng buộc: Một sinh viên chỉ được điểm danh 1 lần cho 1 môn trong 1 ngày
  @@unique([enrollmentId, date])
}

model Grade {
  id              String      @id @default(uuid()) @db.VarChar(50)
  studentId       String      @db.VarChar(50)
  courseClassId   String      @db.VarChar(50)
  subjectId       String      @db.VarChar(50)
  attendanceScore Float?
  midtermScore    Float?
  finalScore      Float?
  totalScore10    Float?
  totalScore4     Float?
  letterGrade     String?     @db.VarChar(10)
  isPassed        Boolean     @default(false)
  
  student         Student     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  courseClass     CourseClass @relation(fields: [courseClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject         Subject     @relation(fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Ràng buộc: 1 sinh viên chỉ có 1 bản ghi điểm cho 1 môn học trong 1 lớp học phần cụ thể
  @@unique([studentId, subjectId, courseClassId])
}

// ============================================================================
// 6. QUẢN LÝ TÀI CHÍNH (CÔNG NỢ HỌC PHÍ)
// ============================================================================
model TuitionFee {
  id            String               @id @default(uuid()) @db.VarChar(50)
  studentId     String               @db.VarChar(50)
  semesterId    String               @db.VarChar(50)
  totalAmount   Decimal              @db.Decimal(12, 2)
  paidAmount    Decimal              @default(0) @db.Decimal(12, 2)
  status        String               @default("DEBT") @db.VarChar(50) // PAID, DEBT, PARTIAL
  dueDate       DateTime?
  paidDate      DateTime?
  paymentMethod String?              @db.VarChar(50)
  
  student       Student              @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  semester      Semester             @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions  TuitionTransaction[]

  // Ràng buộc: Mỗi học kỳ, 1 sinh viên chỉ có duy nhất 1 bản ghi công nợ tổng
  @@unique([studentId, semesterId])
}

model TuitionTransaction {
  id              String     @id @default(uuid()) @db.VarChar(50)
  tuitionFeeId    String     @db.VarChar(50)
  amount          Decimal    @db.Decimal(12, 2)
  paymentMethod   String     @db.VarChar(50)
  transactionDate DateTime   @default(now())
  transactionCode String?    @db.VarChar(100)
  
  tuitionFee      TuitionFee @relation(fields: [tuitionFeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}