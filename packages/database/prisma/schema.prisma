generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 1. QUẢN LÝ NGƯỜI DÙNG & TÀI KHOẢN (IAM)
// ============================================================================
model User {
  id           String    @id @default(uuid()) @db.VarChar(50)
  username     String    @unique @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.NVarChar(255)
  // RoleEnum: SUPER_ADMIN, ACADEMIC_STAFF, LECTURER, STUDENT
  role         String    @default("STUDENT") @db.VarChar(50) 
  avatarUrl    String?   @db.NVarChar(1000)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  
  lecturer     Lecturer?
  student      Student?
}

// ============================================================================
// 2. CƠ CẤU TỔ CHỨC & DANH MỤC ĐÀO TẠO
// ============================================================================
model Faculty {
  id        String     @id @default(uuid()) @db.VarChar(50)
  code      String     @unique @db.VarChar(50)
  name      String     @db.NVarChar(255)
  deanName  String?    @db.NVarChar(255)
  
  lecturers Lecturer[]
  majors    Major[]
}

model Major {
  id                   String       @id @default(uuid()) @db.VarChar(50)
  facultyId            String       @db.VarChar(50)
  code                 String       @unique @db.VarChar(50)
  name                 String       @db.NVarChar(255)
  totalCreditsRequired Int          @default(120) // Phục vụ chart "Tiến độ học tập" (VD: 149/175)
  
  faculty              Faculty      @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminClasses         AdminClass[]
  students             Student[]
  subjects             Subject[]
  curriculums          Curriculum[]
}

// [MỚI] Chương trình khung (Map môn học với từng khóa/ngành - Phục vụ UI Chương trình khung)
model Curriculum {
  id                String  @id @default(uuid()) @db.VarChar(50)
  majorId           String  @db.VarChar(50)
  cohort            String  @db.VarChar(50) // VD: K15, K16
  subjectId         String  @db.VarChar(50)
  suggestedSemester Int     // Học kỳ gợi ý (1-8)
  isMandatory       Boolean @default(true) // Thuộc nhóm bắt buộc hay tự chọn

  major   Major   @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([majorId, cohort, subjectId])
}

model Subject {
  id              String         @id @default(uuid()) @db.VarChar(50)
  majorId         String         @db.VarChar(50)
  code            String         @unique @db.VarChar(50)
  name            String         @db.NVarChar(255)
  credits         Int
  theoryHours     Int            @default(30) // Số tiết LT
  practiceHours   Int            @default(15) // Số tiết TH
  selfStudyHours  Int            @default(0)  // Số tiết tự học
  department      String?        @db.NVarChar(255)
  description     String?        @db.NVarChar(Max)
  
  major           Major          @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  classes         CourseClass[]
  grades          Grade[]
  curriculums     Curriculum[]
  
  requiredFor     Prerequisite[] @relation("PrerequisiteFor")
  prerequisites   Prerequisite[] @relation("SubjectPrerequisites")
}

model Prerequisite {
  id             String  @id @default(uuid()) @db.VarChar(50)
  subjectId      String  @db.VarChar(50)
  prerequisiteId String  @db.VarChar(50)
  type           String  @db.VarChar(50) // PREREQUISITE (Tiên quyết), PARALLEL (Song hành), EQUIVALENT
  
  prerequisite   Subject @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject        Subject @relation("SubjectPrerequisites", fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([subjectId, prerequisiteId])
}

// ============================================================================
// 3. HỒ SƠ SINH VIÊN & GIẢNG VIÊN (PROFILE)
// ============================================================================
model Lecturer {
  id           String        @id @default(uuid()) @db.VarChar(50)
  userId       String        @unique @db.VarChar(50)
  facultyId    String?       @db.VarChar(50)
  lectureCode  String        @unique @db.VarChar(50)
  fullName     String        @db.NVarChar(255)
  degree       String?       @db.NVarChar(100)
  phone        String?       @db.VarChar(20)
  
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faculty      Faculty?      @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  adminClasses AdminClass[]
  classes      CourseClass[]
}

model AdminClass {
  id        String    @id @default(uuid()) @db.VarChar(50)
  majorId   String    @db.VarChar(50)
  code      String    @unique @db.VarChar(50) // VD: DHTI16A4HN
  name      String    @db.NVarChar(255)
  cohort    String?   @db.VarChar(50) // VD: K16
  advisorId String?   @db.VarChar(50)
  
  major     Major     @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  advisor   Lecturer? @relation(fields: [advisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students  Student[]
}

model Student {
  id                 String       @id @default(uuid()) @db.VarChar(50)
  userId             String       @unique @db.VarChar(50)
  adminClassId       String?      @db.VarChar(50)
  majorId            String       @db.VarChar(50)
  studentCode        String       @unique @db.VarChar(50)
  fullName           String       @db.NVarChar(255)
  dob                DateTime     @db.Date
  gender             String?      @db.NVarChar(20)
  phone              String?      @db.VarChar(20)
  address            String?      @db.NVarChar(500)
  citizenId          String?      @db.VarChar(50)
  emailPersonal      String?      @db.VarChar(100)
  
  // [MỚI] Tích hợp chi tiết theo màn hình "Thông tin học vấn"
  admissionDate      DateTime?    @db.Date // Ngày vào trường
  campus             String?      @db.NVarChar(100) // Cơ sở (Hà Nội, Nam Định)
  educationLevel     String?      @db.NVarChar(100) // Bậc đào tạo (Đại học)
  educationType      String?      @db.NVarChar(100) // Loại hình (Chính quy)
  intake             String?      @db.VarChar(50) // Khóa học (2022)

  // [MỚI] Thông tin nhân khẩu & tài khoản ngân hàng
  ethnicity          String?      @db.NVarChar(50) // Dân tộc
  religion           String?      @db.NVarChar(50) // Tôn giáo
  nationality        String?      @db.NVarChar(50) // Quốc tịch
  region             String?      @db.NVarChar(50) // Khu vực
  idIssueDate        DateTime?    @db.Date // Ngày cấp CCCD
  idIssuePlace       String?      @db.NVarChar(200) // Nơi cấp CCCD
  policyBeneficiary  String?      @db.NVarChar(200) // Diện chính sách
  youthUnionDate     DateTime?    @db.Date // Ngày vào Đoàn
  partyDate          DateTime?    @db.Date // Ngày vào Đảng
  birthPlace         String?      @db.NVarChar(200) // Nơi sinh
  permanentAddress   String?      @db.NVarChar(500) // Hộ khẩu thường trú
  bankName           String?      @db.NVarChar(100) // Tên ngân hàng
  bankBranch         String?      @db.NVarChar(100) // Chi nhánh NH
  bankAccountName    String?      @db.NVarChar(100) // Tên CTK
  bankAccountNumber  String?      @db.VarChar(50) // Số tài khoản

  // Thống kê học tập
  gpa                Float        @default(0.0) // TB Học kỳ
  cpa                Float        @default(0.0) // TB Tích lũy
  totalEarnedCredits Int          @default(0) // Tín chỉ tích lũy
  status             String       @default("STUDYING") @db.VarChar(50) 
  
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  adminClass         AdminClass?  @relation(fields: [adminClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major              Major        @relation(fields: [majorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  enrollments        Enrollment[]
  grades             Grade[]
  trainingScores     TrainingScore[]
  studentFees        StudentFee[]
  familyMembers      FamilyMember[]
}

// [MỚI] Quan hệ gia đình
model FamilyMember {
  id           String  @id @default(uuid()) @db.VarChar(50)
  studentId    String  @db.VarChar(50)
  relationship String  @db.NVarChar(50) // Cha, Mẹ, Người bảo hộ
  fullName     String  @db.NVarChar(255)
  birthYear    Int?
  job          String? @db.NVarChar(200)
  phone        String? @db.VarChar(20)
  ethnicity    String? @db.NVarChar(50)
  religion     String? @db.NVarChar(50)
  nationality  String? @db.NVarChar(50)
  workplace    String? @db.NVarChar(255)
  position     String? @db.NVarChar(100)
  address      String? @db.NVarChar(500)

  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// [MỚI] Kết quả rèn luyện
model TrainingScore {
  id             String   @id @default(uuid()) @db.VarChar(50)
  studentId      String   @db.VarChar(50)
  semesterId     String   @db.VarChar(50)
  score          Int      // Điểm rèn luyện (VD: 81)
  classification String   @db.NVarChar(50) // Xếp loại (VD: Tốt)

  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semester       Semester @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([studentId, semesterId])
}

// ============================================================================
// 4. VẬN HÀNH ĐÀO TẠO & XẾP LỊCH
// ============================================================================
model Semester {
  id                String          @id @default(uuid()) @db.VarChar(50)
  code              String          @unique @db.VarChar(50)
  name              String          @db.NVarChar(255)
  year              Int             @default(2024)
  startDate         DateTime        @db.Date
  endDate           DateTime        @db.Date
  isCurrent         Boolean         @default(false)
  isRegistering     Boolean         @default(false) // Trạng thái cổng đăng ký
  registerStartDate DateTime?
  registerEndDate   DateTime?
  
  classes           CourseClass[]
  trainingScores    TrainingScore[]
  studentFees       StudentFee[]
}

model Room {
  id        String          @id @default(uuid()) @db.VarChar(50)
  name      String          @unique @db.VarChar(100)
  building  String?         @db.VarChar(100)
  capacity  Int             @default(50)
  type      String          @default("THEORY") @db.VarChar(50) // THEORY, PRACTICE
  
  schedules ClassSchedule[]
}

model CourseClass {
  id                String          @id @default(uuid()) @db.VarChar(50)
  subjectId         String          @db.VarChar(50)
  semesterId        String          @db.VarChar(50)
  lecturerId        String?         @db.VarChar(50)
  code              String          @unique @db.VarChar(50) // VD: 010100277704
  name              String          @db.NVarChar(255)
  adminClassCode    String?         @db.VarChar(50) // Lớp dự kiến
  tuitionMultiplier Float           @default(1.0)
  maxSlots          Int             @default(60)
  currentSlots      Int             @default(0)
  status            String          @default("OPEN") @db.VarChar(50) // OPEN, CLOSED, LOCKED
  
  subject           Subject         @relation(fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester          Semester        @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lecturer          Lecturer?       @relation(fields: [lecturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  schedules         ClassSchedule[]
  enrollments       Enrollment[]
  grades            Grade[]
}

model ClassSchedule {
  id            String      @id @default(uuid()) @db.VarChar(50)
  courseClassId String      @db.VarChar(50)
  roomId        String?     @db.VarChar(50)
  dayOfWeek     Int         // Thứ (2-8)
  startShift    Int         // Tiết bắt đầu (1-12)
  endShift      Int         // Tiết kết thúc
  type          String      @db.VarChar(50) // THEORY, PRACTICE
  
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  room          Room?       @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomId, dayOfWeek, startShift])
}

// ============================================================================
// 5. ĐĂNG KÝ HỌC, ĐIỂM DANH & KẾT QUẢ
// ============================================================================
model Enrollment {
  id                String       @id @default(uuid()) @db.VarChar(50)
  studentId         String       @db.VarChar(50)
  courseClassId     String       @db.VarChar(50)
  status            String       @default("REGISTERED") @db.VarChar(50) // NEW, RETAKE, IMPROVEMENT
  registeredAt      DateTime     @default(now())
  isRetake          Boolean      @default(false) // Học lại
  tuitionFee        Decimal      @default(0) @db.Decimal(10, 2)
  
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  courseClass       CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  
  attendances       Attendance[]

  @@unique([studentId, courseClassId])
}

// Chi tiết điểm danh
model Attendance {
  id           String     @id @default(uuid()) @db.VarChar(50)
  enrollmentId String     @db.VarChar(50)
  date         DateTime   @db.Date
  status       String     @default("PRESENT") @db.VarChar(50) // PRESENT, ABSENT_EXCUSED, ABSENT_UNEXCUSED
  note         String?    @db.NVarChar(255)
  
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, date])
}

// Bảng điểm chi tiết (Map với UI Kết quả học tập)
model Grade {
  id                String      @id @default(uuid()) @db.VarChar(50)
  studentId         String      @db.VarChar(50)
  courseClassId     String      @db.VarChar(50)
  subjectId         String      @db.VarChar(50)
  
  // Các thành phần điểm chi tiết
  attendanceScore   Float?      // Chuyên cần
  regularScore1     Float?      // LT Hệ số 1 (TB)
  regularScore2     Float?      // LT Hệ số 2 (TB)
  practiceScore     Float?      // Thực hành
  midtermScore      Float?      // Giữa kỳ / Điểm TB thường xuyên
  
  isEligibleForExam Boolean     @default(true) // Cờ "Được dự thi"
  isAbsentFromExam  Boolean     @default(false)// Cờ "Vắng thi"
  finalScore        Float?      // Điểm thi Cuối kỳ
  
  // Điểm tổng kết
  totalScore10      Float?      // Thang 10
  totalScore4       Float?      // Thang 4
  letterGrade       String?     @db.VarChar(10) // Điểm chữ (A, B+, C...)
  isPassed          Boolean     @default(false)
  
  isLocked          Boolean     @default(false) // Cờ khóa điểm từ Giảng viên
  
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  courseClass       CourseClass @relation(fields: [courseClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject           Subject     @relation(fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([studentId, subjectId, courseClassId])
}

// ============================================================================
// 6. QUẢN LÝ TÀI CHÍNH (CÔNG NỢ, BHYT)
// ============================================================================
// [MỚI] Cấu hình học phí theo ngành
model TuitionConfig {
  id             String   @id @default(uuid()) @db.VarChar(50)
  majorId        String   @db.VarChar(50)
  academicYear   Int
  pricePerCredit Decimal  @db.Decimal(12, 2)
}

// [MỚI] Phục vụ tra cứu công nợ (Bao gồm Học phí và Thu khác)
model StudentFee {
  id             String               @id @default(uuid()) @db.VarChar(50)
  studentId      String               @db.VarChar(50)
  semesterId     String               @db.VarChar(50)
  
  feeType        String               @db.VarChar(50) // TUITION (Học phí), INSURANCE (BHYT), OTHER (Phúc khảo, KSK)
  name           String               @db.NVarChar(255) // VD: Bảo hiểm y tế đầu năm
  isMandatory    Boolean              @default(true) // Cột "Bắt buộc"
  
  totalAmount    Decimal              @db.Decimal(12, 2) // Mức phí ban đầu
  discountAmount Decimal              @default(0) @db.Decimal(12, 2) // Tiền miễn giảm
  finalAmount    Decimal              @db.Decimal(12, 2) // Mức nộp thực tế
  paidAmount     Decimal              @default(0) @db.Decimal(12, 2) // Số tiền đã nộp
  
  status         String               @default("DEBT") @db.VarChar(50) // PAID, DEBT, PARTIAL
  dueDate        DateTime?            @db.Date
  
  student        Student              @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  semester       Semester             @relation(fields: [semesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions   FeeTransaction[]
}

model FeeTransaction {
  id              String     @id @default(uuid()) @db.VarChar(50)
  studentFeeId    String     @db.VarChar(50)
  amount          Decimal    @db.Decimal(12, 2) // Số tiền nộp / Khấu trừ / Trừ nợ
  transactionType String     @default("PAYMENT") @db.VarChar(50) // PAYMENT (Thanh toán), DEDUCTION (Khấu trừ)
  paymentMethod   String     @db.VarChar(50) // BANKING, MOMO...
  transactionDate DateTime   @default(now())
  transactionCode String?    @db.VarChar(100)
  
  studentFee      StudentFee @relation(fields: [studentFeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}