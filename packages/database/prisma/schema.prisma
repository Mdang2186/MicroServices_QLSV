generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.VarChar(50)
  username      String         @unique @db.VarChar(100)
  email         String         @unique @db.VarChar(100)
  passwordHash  String         @db.NVarChar(255)
  role          String         @default("STUDENT") @db.VarChar(50)
  avatarUrl     String?
  isActive      Boolean        @default(true)
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  lecturer      Lecturer?
  notifications Notification[]
  student       Student?
}

model Notification {
  id        String   @id @default(uuid()) @db.VarChar(50)
  userId    String   @db.VarChar(50)
  title     String   @db.NVarChar(255)
  content   String   @db.NVarChar(Max)
  type      String   @default("INFO") @db.VarChar(50)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Faculty {
  id          String       @id @default(uuid()) @db.VarChar(50)
  code        String       @unique @db.VarChar(50)
  name        String       @db.NVarChar(255)
  deanName    String?      @db.NVarChar(255)
  departments Department[]
  lecturers   Lecturer[]
  majors      Major[]
}

model Department {
  id        String     @id @default(uuid()) @db.VarChar(50)
  facultyId String     @db.VarChar(50)
  code      String     @unique @db.VarChar(50)
  name      String     @db.NVarChar(255)
  headName  String?    @db.NVarChar(255)
  faculty   Faculty    @relation(fields: [facultyId], references: [id], onUpdate: NoAction)
  lecturers Lecturer[]
  subjects  Subject[]
}

model Major {
  id                    String                 @id @default(uuid()) @db.VarChar(50)
  facultyId             String                 @db.VarChar(50)
  code                  String                 @unique @db.VarChar(50)
  name                  String                 @db.NVarChar(255)
  totalCreditsRequired  Int                    @default(120)
  adminClasses          AdminClass[]
  curriculums           Curriculum[]
  faculty               Faculty                @relation(fields: [facultyId], references: [id], onUpdate: NoAction)
  semesterPlans         SemesterPlan[]
  specializations       Specialization[]
  students              Student[]
  subjects              Subject[]
  trainingPlanTemplates TrainingPlanTemplate[]
}

model AcademicCohort {
  code                  String                 @id @db.VarChar(50)
  startYear             Int
  endYear               Int
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  semesterPlans         SemesterPlan[]
  trainingPlanTemplates TrainingPlanTemplate[]
}

model Specialization {
  id          String    @id @default(uuid()) @db.VarChar(50)
  majorId     String    @db.VarChar(50)
  code        String    @unique @db.VarChar(50)
  name        String    @db.NVarChar(255)
  description String?   @db.NVarChar(Max)
  major       Major     @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  students    Student[]
}

model Curriculum {
  id                String   @id(map: "PK__Curricul__3213E83F6570CBC5") @default(uuid()) @db.VarChar(50)
  majorId           String   @db.VarChar(50)
  subjectId         String   @db.VarChar(50)
  isRequired        Boolean? @default(true, map: "DF__Curriculu__isReq__3CF40B7E")
  cohort            String   @default("K18") @db.VarChar(50)
  suggestedSemester Int      @default(1)
  major             Major    @relation(fields: [majorId], references: [id], onUpdate: NoAction, map: "FK_Curriculum_Major")
  subject           Subject  @relation(fields: [subjectId], references: [id], onUpdate: NoAction, map: "FK_Curriculum_Subject")

  @@unique([majorId, cohort, subjectId])
}

model Subject {
  id                                                                     String                     @id @default(uuid()) @db.VarChar(50)
  majorId                                                                String                     @db.VarChar(50)
  code                                                                   String                     @unique @db.VarChar(50)
  name                                                                   String                     @db.NVarChar(255)
  credits                                                                Int
  theoryHours                                                            Int                        @default(30)
  practiceHours                                                          Int                        @default(15)
  selfStudyHours                                                         Int                        @default(0)
  description                                                            String?                    @db.NVarChar(Max)
  departmentId                                                           String?                    @db.VarChar(50)
  examDuration                                                           Int                        @default(90)
  examType                                                               String                     @default("TRAC_NGHIEM") @db.VarChar(50)
  examForm                                                               String                     @default("T? lu?n") @db.VarChar(50)
  theoryPeriods                                                          Int?                       @default(0, map: "DF__Subject__theoryP__5E8A0973")
  practicePeriods                                                        Int?                       @default(0, map: "DF__Subject__practic__5F7E2DAC")
  practiceSessionsPerWeek                                                Int                        @default(1)
  theorySessionsPerWeek                                                  Int                        @default(1)
  classes                                                                CourseClass[]
  curriculums                                                            Curriculum[]
  grades                                                                 Grade[]
  requiredFor                                                            Prerequisite[]             @relation("PrerequisiteFor")
  prerequisites                                                          Prerequisite[]             @relation("SubjectPrerequisites")
  semesterPlanItems                                                      SemesterPlanItem[]
  department                                                             Department?                @relation(fields: [departmentId], references: [id], onUpdate: NoAction)
  major                                                                  Major                      @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  SubjectPrerequisite_SubjectPrerequisite_subjectIdToSubject             SubjectPrerequisite[]      @relation("SubjectPrerequisite_subjectIdToSubject")
  SubjectPrerequisite_SubjectPrerequisite_prerequisiteSubjectIdToSubject SubjectPrerequisite[]      @relation("SubjectPrerequisite_prerequisiteSubjectIdToSubject")
  trainingPlanTemplateItems                                              TrainingPlanTemplateItem[]
}

model Prerequisite {
  id             String  @id @default(uuid()) @db.VarChar(50)
  subjectId      String  @db.VarChar(50)
  prerequisiteId String  @db.VarChar(50)
  type           String  @db.VarChar(50)
  prerequisite   Subject @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject        Subject @relation("SubjectPrerequisites", fields: [subjectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([subjectId, prerequisiteId])
}

model Lecturer {
  id                String             @id @default(uuid()) @db.VarChar(50)
  userId            String?            @unique @db.VarChar(50)
  facultyId         String?            @db.VarChar(50)
  lectureCode       String             @unique @db.VarChar(50)
  fullName          String             @db.NVarChar(255)
  degree            String?            @db.NVarChar(100)
  phone             String?            @db.VarChar(20)
  departmentId      String?            @db.VarChar(50)
  adminClasses      AdminClass[]
  classes           CourseClass[]
  department        Department?        @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  faculty           Faculty?           @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  semesterPlanItems SemesterPlanItem[]
}

model AdminClass {
  id                String             @id @default(uuid()) @db.VarChar(50)
  majorId           String             @db.VarChar(50)
  code              String             @unique @db.VarChar(50)
  name              String             @db.NVarChar(255)
  cohort            String?            @db.VarChar(50)
  advisorId         String?            @db.VarChar(50)
  advisor           Lecturer?          @relation(fields: [advisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major             Major              @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  semesterPlanItems SemesterPlanItem[]
  students          Student[]
  courseClasses     CourseClass[]      @relation("AdminClassToCourseClass")
}

model Student {
  id                 String          @id @default(uuid()) @db.VarChar(50)
  userId             String?         @unique @db.VarChar(50)
  adminClassId       String?         @db.VarChar(50)
  majorId            String          @db.VarChar(50)
  studentCode        String          @unique @db.VarChar(50)
  fullName           String          @db.NVarChar(255)
  dob                DateTime        @db.Date
  gender             String?         @db.NVarChar(20)
  phone              String?         @db.VarChar(20)
  address            String?         @db.NVarChar(500)
  citizenId          String?         @db.VarChar(50)
  emailPersonal      String?         @db.VarChar(100)
  admissionDate      DateTime?       @db.Date
  campus             String?         @db.NVarChar(100)
  educationLevel     String?         @db.NVarChar(100)
  educationType      String?         @db.NVarChar(100)
  intake             String?         @db.VarChar(50)
  ethnicity          String?         @db.NVarChar(50)
  religion           String?         @db.NVarChar(50)
  nationality        String?         @db.NVarChar(50)
  region             String?         @db.NVarChar(50)
  idIssueDate        DateTime?       @db.Date
  idIssuePlace       String?         @db.NVarChar(200)
  policyBeneficiary  String?         @db.NVarChar(200)
  youthUnionDate     DateTime?       @db.Date
  partyDate          DateTime?       @db.Date
  birthPlace         String?         @db.NVarChar(200)
  permanentAddress   String?         @db.NVarChar(500)
  bankName           String?         @db.NVarChar(100)
  bankBranch         String?         @db.NVarChar(100)
  bankAccountName    String?         @db.NVarChar(100)
  bankAccountNumber  String?         @db.VarChar(50)
  gpa                Float           @default(0.0)
  cpa                Float           @default(0.0)
  totalEarnedCredits Int             @default(0)
  status             String          @default("STUDYING") @db.VarChar(50)
  specializationId   String?         @db.VarChar(50)
  academicStatus     String          @default("NORMAL") @db.VarChar(50)
  warningLevel       Int             @default(0)
  enrollments        Enrollment[]
  familyMembers      FamilyMember[]
  grades             Grade[]
  adminClass         AdminClass?     @relation(fields: [adminClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major              Major           @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  specialization     Specialization? @relation(fields: [specializationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user               User?           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  studentFees        StudentFee[]
  trainingScores     TrainingScore[]
}

model FamilyMember {
  id           String  @id @default(uuid()) @db.VarChar(50)
  studentId    String  @db.VarChar(50)
  relationship String  @db.NVarChar(50)
  fullName     String  @db.NVarChar(255)
  birthYear    Int?
  job          String? @db.NVarChar(200)
  phone        String? @db.VarChar(20)
  ethnicity    String? @db.NVarChar(50)
  religion     String? @db.NVarChar(50)
  nationality  String? @db.NVarChar(50)
  workplace    String? @db.NVarChar(255)
  position     String? @db.NVarChar(100)
  address      String? @db.NVarChar(500)
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TrainingScore {
  id             String   @id @default(uuid()) @db.VarChar(50)
  studentId      String   @db.VarChar(50)
  semesterId     String   @db.VarChar(50)
  score          Int
  classification String   @db.NVarChar(50)
  semester       Semester @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semesterId])
}

model Semester {
  id                   String          @id @default(uuid()) @db.VarChar(50)
  code                 String          @unique @db.VarChar(50)
  name                 String          @db.NVarChar(255)
  year                 Int             @default(2024)
  startDate            DateTime        @db.Date
  endDate              DateTime        @db.Date
  isCurrent            Boolean         @default(false)
  isRegistering        Boolean         @default(false)
  registerStartDate    DateTime?
  registerEndDate      DateTime?
  midtermGradeDeadline DateTime?
  examEndDate          DateTime?       @db.Date
  examStartDate        DateTime?       @db.Date
  semesterNumber       Int             @default(1)
  sessions             ClassSession[]
  classes              CourseClass[]
  semesterPlans        SemesterPlan[]
  studentFees          StudentFee[]
  TeachingPlan         TeachingPlan[]
  trainingScores       TrainingScore[]
}

model Room {
  id        String          @id @default(uuid()) @db.VarChar(50)
  name      String          @unique @db.NVarChar(255)
  building  String?         @db.NVarChar(255)
  capacity  Int             @default(50)
  examCapacity Int             @default(30)
  type      String          @default("THEORY") @db.VarChar(50)
  campus    String?         @db.NVarChar(100)
  schedules ClassSchedule[]
  sessions  ClassSession[]
}

model CourseClass {
  id                 String             @id @default(uuid()) @db.VarChar(50)
  subjectId          String             @db.VarChar(50)
  semesterId         String             @db.VarChar(50)
  lecturerId         String?            @db.VarChar(50)
  code               String             @unique @db.VarChar(50)
  name               String             @db.NVarChar(255)
  tuitionMultiplier  Float              @default(1.0)
  maxSlots           Int                @default(60)
  currentSlots       Int                @default(0)
  status             String             @default("OPEN") @db.VarChar(50)
  totalPeriods       Int                @default(45)
  cohort             String?            @db.VarChar(50)
  periodsPerSession  Int?               @default(3)
  sessionsPerWeek    Int?               @default(1)
  sessions           ClassSession[]
  lecturer           Lecturer?          @relation(fields: [lecturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester           Semester           @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  subject            Subject            @relation(fields: [subjectId], references: [id], onUpdate: NoAction)
  enrollments        Enrollment[]
  grades             Grade[]
  generatedPlanItems SemesterPlanItem[] @relation("GeneratedCourseClass")
  TeachingPlan       TeachingPlan[]
  adminClasses       AdminClass[]       @relation("AdminClassToCourseClass")
}

model TrainingPlanTemplate {
  id                   String                     @id @default(uuid()) @db.VarChar(50)
  majorId              String                     @db.VarChar(50)
  cohort               String                     @db.VarChar(50)
  version              Int
  status               String                     @default("DRAFT") @db.VarChar(50)
  publishedAt          DateTime?
  copiedFromTemplateId String?                    @db.VarChar(50)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @default(now()) @updatedAt
  semesterPlans        SemesterPlan[]
  academicCohort       AcademicCohort             @relation(fields: [cohort], references: [code], onUpdate: NoAction, map: "FK_TrainingPlanTemplate_AcademicCohort")
  copiedFromTemplate   TrainingPlanTemplate?      @relation("TrainingPlanTemplateCopy", fields: [copiedFromTemplateId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_TrainingPlanTemplate_Copy")
  copiedTemplates      TrainingPlanTemplate[]     @relation("TrainingPlanTemplateCopy")
  major                Major                      @relation(fields: [majorId], references: [id], onUpdate: NoAction, map: "FK_TrainingPlanTemplate_Major")
  items                TrainingPlanTemplateItem[]

  @@unique([majorId, cohort, version])
  @@index([majorId, cohort, status])
}

model TrainingPlanTemplateItem {
  id                      String               @id @default(uuid()) @db.VarChar(50)
  templateId              String               @db.VarChar(50)
  subjectId               String               @db.VarChar(50)
  conceptualSemester      Int
  isRequired              Boolean              @default(true)
  theoryPeriods           Int?
  practicePeriods         Int?
  theorySessionsPerWeek   Int?
  practiceSessionsPerWeek Int?
  periodsPerSession       Int?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @default(now()) @updatedAt
  subject                 Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_TrainingPlanTemplateItem_Subject")
  template                TrainingPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_TrainingPlanTemplateItem_Template")

  @@unique([templateId, subjectId])
  @@index([templateId, conceptualSemester])
}

model SemesterPlan {
  id                 String               @id @default(uuid()) @db.VarChar(50)
  semesterId         String               @db.VarChar(50)
  majorId            String               @db.VarChar(50)
  cohort             String               @db.VarChar(50)
  templateId         String               @db.VarChar(50)
  templateVersion    Int
  conceptualSemester Int
  status             String               @default("DRAFT") @db.VarChar(50)
  executedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  academicCohort     AcademicCohort       @relation(fields: [cohort], references: [code], onUpdate: NoAction, map: "FK_SemesterPlan_AcademicCohort")
  major              Major                @relation(fields: [majorId], references: [id], onUpdate: NoAction, map: "FK_SemesterPlan_Major")
  semester           Semester             @relation(fields: [semesterId], references: [id], onUpdate: NoAction, map: "FK_SemesterPlan_Semester")
  template           TrainingPlanTemplate @relation(fields: [templateId], references: [id], onUpdate: NoAction, map: "FK_SemesterPlan_Template")
  items              SemesterPlanItem[]

  @@unique([semesterId, majorId, cohort])
  @@index([majorId, cohort, status])
}

model SemesterPlanItem {
  id                      String       @id @default(uuid()) @db.VarChar(50)
  semesterPlanId          String       @db.VarChar(50)
  subjectId               String       @db.VarChar(50)
  adminClassId            String       @db.VarChar(50)
  lecturerId              String?      @db.VarChar(50)
  status                  String       @default("DRAFT") @db.VarChar(50)
  expectedStudentCount    Int          @default(0)
  generatedCourseClassId  String?      @db.VarChar(50)
  theoryPeriods           Int?
  practicePeriods         Int?
  theorySessionsPerWeek   Int?
  practiceSessionsPerWeek Int?
  periodsPerSession       Int?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @default(now()) @updatedAt
  adminClass              AdminClass   @relation(fields: [adminClassId], references: [id], onUpdate: NoAction, map: "FK_SemesterPlanItem_AdminClass")
  generatedCourseClass    CourseClass? @relation("GeneratedCourseClass", fields: [generatedCourseClassId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_SemesterPlanItem_CourseClass")
  lecturer                Lecturer?    @relation(fields: [lecturerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_SemesterPlanItem_Lecturer")
  semesterPlan            SemesterPlan @relation(fields: [semesterPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_SemesterPlanItem_SemesterPlan")
  subject                 Subject      @relation(fields: [subjectId], references: [id], onUpdate: NoAction, map: "FK_SemesterPlanItem_Subject")

  @@unique([semesterPlanId, subjectId, adminClassId])
  @@index([generatedCourseClassId])
  @@index([lecturerId])
  @@index([status])
}

model ClassSchedule {
  id           String       @id(map: "PK__ClassSch__3213E83FABA7CEB6") @default(uuid()) @db.VarChar(50)
  planId       String       @db.VarChar(50)
  studyDate    DateTime     @db.Date
  startPeriod  Int
  endPeriod    Int
  roomId       String?      @db.VarChar(50)
  type         String?      @default("N'STUDY'", map: "DF__ClassSched__type__477199F1") @db.NVarChar(50)
  room         Room?        @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  TeachingPlan TeachingPlan @relation(fields: [planId], references: [id], onUpdate: NoAction, map: "FK_Schedule_TP")
}

model ClassSession {
  id            String       @id @default(uuid()) @db.VarChar(50)
  courseClassId String       @db.VarChar(50)
  roomId        String?      @db.VarChar(50)
  semesterId    String       @db.VarChar(50)
  date          DateTime     @db.Date
  startShift    Int
  endShift      Int
  type          String       @default("LECTURE") @db.VarChar(50)
  note          String?      @db.NVarChar(255)
  attendances   Attendance[]
  courseClass   CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  room          Room?        @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester      Semester     @relation(fields: [semesterId], references: [id], onUpdate: NoAction)

  @@unique([roomId, date, startShift, semesterId])
}

model Enrollment {
  id            String       @id @default(uuid()) @db.VarChar(50)
  studentId     String       @db.VarChar(50)
  courseClassId String       @db.VarChar(50)
  status        String       @default("REGISTERED") @db.VarChar(50)
  registeredAt  DateTime     @default(now())
  isRetake      Boolean      @default(false)
  tuitionFee    Decimal      @default(0) @db.Decimal(10, 2)
  attendances   Attendance[]
  courseClass   CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([studentId, courseClassId])
}

model Attendance {
  id           String        @id @default(uuid()) @db.VarChar(50)
  enrollmentId String        @db.VarChar(50)
  date         DateTime      @db.Date
  status       String        @default("PRESENT") @db.VarChar(50)
  note         String?       @db.NVarChar(255)
  sessionId    String?       @db.VarChar(50)
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onUpdate: NoAction)
  session      ClassSession? @relation(fields: [sessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([enrollmentId, date])
}

model Grade {
  id                String      @id @default(uuid()) @db.VarChar(50)
  studentId         String      @db.VarChar(50)
  courseClassId     String      @db.VarChar(50)
  subjectId         String      @db.VarChar(50)
  attendanceScore   Float?
  isEligibleForExam Boolean     @default(true)
  isAbsentFromExam  Boolean     @default(false)
  totalScore10      Float?
  totalScore4       Float?
  letterGrade       String?     @db.VarChar(10)
  isPassed          Boolean     @default(false)
  isLocked          Boolean     @default(false)
  status            String      @default("DRAFT") @db.VarChar(50)
  coef1Scores       String?     @db.NVarChar(Max)
  coef2Scores       String?     @db.NVarChar(Max)
  examScore1        Float?
  examScore2        Float?
  finalScore1       Float?
  finalScore2       Float?
  notes             String?     @db.NVarChar(500)
  practiceScores    String?     @db.NVarChar(Max)
  regularScores     String?     @db.NVarChar(Max)
  tbThuongKy        Float?
  examSbd           String?     @db.VarChar(50)
  examSessionId     String?     @db.VarChar(50)
  courseClass       CourseClass @relation(fields: [courseClassId], references: [id], onUpdate: NoAction)
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subject           Subject     @relation(fields: [subjectId], references: [id], onUpdate: NoAction)

  @@unique([studentId, subjectId, courseClassId])
}

model TuitionConfig {
  id             String    @id @default(uuid()) @db.VarChar(50)
  majorId        String    @db.VarChar(50)
  academicYear   Int
  pricePerCredit Decimal   @db.Decimal(12, 2)
  cohort         String?   @db.VarChar(50)
  educationType  String?   @db.NVarChar(100)
  effectiveFrom  DateTime? @db.Date
  effectiveTo    DateTime? @db.Date
  isActive       Boolean   @default(true)
}

model StudentFee {
  id             String           @id @default(uuid()) @db.VarChar(50)
  studentId      String           @db.VarChar(50)
  semesterId     String           @db.VarChar(50)
  feeType        String           @db.VarChar(50)
  name           String           @db.NVarChar(255)
  isMandatory    Boolean          @default(true)
  totalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @default(0) @db.Decimal(12, 2)
  status         String           @default("DEBT") @db.VarChar(50)
  dueDate        DateTime?        @db.Date
  configId       String?          @db.VarChar(50)
  displayOrder   Int              @default(0)
  feeCode        String?          @db.VarChar(50)
  transactions   FeeTransaction[]
  semester       Semester         @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model FixedFeeConfig {
  id                  String    @id @default(uuid()) @db.VarChar(50)
  academicYear        Int
