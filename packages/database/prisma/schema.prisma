  totalPeriods  Int?            @default(0, map: "DF__TeachingP__total__42ACE4D4")
  ClassSchedule ClassSchedule[]
  CourseClass   CourseClass     @relation(fields: [courseClassId], references: [id], onUpdate: NoAction, map: "FK_TP_CourseClass")
