generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.VarChar(50)
  username      String         @unique @db.VarChar(100)
  email         String         @unique @db.VarChar(100)
  passwordHash  String         @db.NVarChar(255)
  role          String         @default("STUDENT") @db.VarChar(50)
  avatarUrl     String?
  isActive      Boolean        @default(true)
  lastLogin     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  lecturer      Lecturer?
  notifications Notification[]
  student       Student?
}

model Notification {
  id        String   @id @default(uuid()) @db.VarChar(50)
  userId    String   @db.VarChar(50)
  title     String   @db.NVarChar(255)
  content   String   @db.NVarChar(Max)
  type      String   @default("INFO") @db.VarChar(50)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Faculty {
  id        String     @id @default(uuid()) @db.VarChar(50)
  code      String     @unique @db.VarChar(50)
  name      String     @db.NVarChar(255)
  deanName  String?    @db.NVarChar(255)
  lecturers Lecturer[]
  majors    Major[]
}

model Major {
  id                   String           @id @default(uuid()) @db.VarChar(50)
  facultyId            String           @db.VarChar(50)
  code                 String           @unique @db.VarChar(50)
  name                 String           @db.NVarChar(255)
  totalCreditsRequired Int              @default(120)
  adminClasses         AdminClass[]
  curriculums          Curriculum[]
  faculty              Faculty          @relation(fields: [facultyId], references: [id], onUpdate: NoAction)
  specializations      Specialization[]
  students             Student[]
  subjects             Subject[]
}

model Specialization {
  id          String    @id @default(uuid()) @db.VarChar(50)
  majorId     String    @db.VarChar(50)
  code        String    @unique @db.VarChar(50)
  name        String    @db.NVarChar(255)
  description String?   @db.NVarChar(Max)
  major       Major     @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  students    Student[]
}

model Curriculum {
  id                String  @id @default(uuid()) @db.VarChar(50)
  majorId           String  @db.VarChar(50)
  cohort            String  @db.VarChar(50)
  subjectId         String  @db.VarChar(50)
  suggestedSemester Int
  isMandatory       Boolean @default(true)
  major             Major   @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  subject           Subject @relation(fields: [subjectId], references: [id], onUpdate: NoAction)

  @@unique([majorId, cohort, subjectId])
}

model Subject {
  id             String         @id @default(uuid()) @db.VarChar(50)
  majorId        String         @db.VarChar(50)
  code           String         @unique @db.VarChar(50)
  name           String         @db.NVarChar(255)
  credits        Int
  theoryHours    Int            @default(30)
  practiceHours  Int            @default(15)
  selfStudyHours Int            @default(0)
  department     String?        @db.NVarChar(255)
  description    String?        @db.NVarChar(Max)
  classes        CourseClass[]
  curriculums    Curriculum[]
  grades         Grade[]
  requiredFor    Prerequisite[] @relation("PrerequisiteFor")
  prerequisites  Prerequisite[] @relation("SubjectPrerequisites")
  major          Major          @relation(fields: [majorId], references: [id], onUpdate: NoAction)
}

model Prerequisite {
  id             String  @id @default(uuid()) @db.VarChar(50)
  subjectId      String  @db.VarChar(50)
  prerequisiteId String  @db.VarChar(50)
  type           String  @db.VarChar(50)
  prerequisite   Subject @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id], onUpdate: NoAction)
  subject        Subject @relation("SubjectPrerequisites", fields: [subjectId], references: [id], onUpdate: NoAction)

  @@unique([subjectId, prerequisiteId])
}

model Lecturer {
  id           String        @id @default(uuid()) @db.VarChar(50)
  userId       String?       @unique @db.VarChar(50)
  facultyId    String?       @db.VarChar(50)
  lectureCode  String        @unique @db.VarChar(50)
  fullName     String        @db.NVarChar(255)
  degree       String?       @db.NVarChar(100)
  phone        String?       @db.VarChar(20)
  adminClasses AdminClass[]
  classes      CourseClass[]
  faculty      Faculty?      @relation(fields: [facultyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model AdminClass {
  id            String        @id @default(uuid()) @db.VarChar(50)
  majorId       String        @db.VarChar(50)
  code          String        @unique @db.VarChar(50)
  name          String        @db.NVarChar(255)
  cohort        String?       @db.VarChar(50)
  advisorId     String?       @db.VarChar(50)
  advisor       Lecturer?     @relation(fields: [advisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major         Major         @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  students      Student[]
  courseClasses CourseClass[] @relation("AdminClassToCourseClass")
}

model Student {
  id                 String          @id @default(uuid()) @db.VarChar(50)
  userId             String?         @unique @db.VarChar(50)
  adminClassId       String?         @db.VarChar(50)
  majorId            String          @db.VarChar(50)
  studentCode        String          @unique @db.VarChar(50)
  fullName           String          @db.NVarChar(255)
  dob                DateTime        @db.Date
  gender             String?         @db.NVarChar(20)
  phone              String?         @db.VarChar(20)
  address            String?         @db.NVarChar(500)
  citizenId          String?         @db.VarChar(50)
  emailPersonal      String?         @db.VarChar(100)
  admissionDate      DateTime?       @db.Date
  campus             String?         @db.NVarChar(100)
  educationLevel     String?         @db.NVarChar(100)
  educationType      String?         @db.NVarChar(100)
  intake             String?         @db.VarChar(50)
  ethnicity          String?         @db.NVarChar(50)
  religion           String?         @db.NVarChar(50)
  nationality        String?         @db.NVarChar(50)
  region             String?         @db.NVarChar(50)
  idIssueDate        DateTime?       @db.Date
  idIssuePlace       String?         @db.NVarChar(200)
  policyBeneficiary  String?         @db.NVarChar(200)
  youthUnionDate     DateTime?       @db.Date
  partyDate          DateTime?       @db.Date
  birthPlace         String?         @db.NVarChar(200)
  permanentAddress   String?         @db.NVarChar(500)
  bankName           String?         @db.NVarChar(100)
  bankBranch         String?         @db.NVarChar(100)
  bankAccountName    String?         @db.NVarChar(100)
  bankAccountNumber  String?         @db.VarChar(50)
  gpa                Float           @default(0.0)
  cpa                Float           @default(0.0)
  totalEarnedCredits Int             @default(0)
  status             String          @default("STUDYING") @db.VarChar(50)
  specializationId   String?         @db.VarChar(50)
  academicStatus     String          @default("NORMAL") @db.VarChar(50)
  warningLevel       Int             @default(0)
  enrollments        Enrollment[]
  familyMembers      FamilyMember[]
  grades             Grade[]
  adminClass         AdminClass?     @relation(fields: [adminClassId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  major              Major           @relation(fields: [majorId], references: [id], onUpdate: NoAction)
  specialization     Specialization? @relation(fields: [specializationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user               User?           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  studentFees        StudentFee[]
  trainingScores     TrainingScore[]
}

model FamilyMember {
  id           String  @id @default(uuid()) @db.VarChar(50)
  studentId    String  @db.VarChar(50)
  relationship String  @db.NVarChar(50)
  fullName     String  @db.NVarChar(255)
  birthYear    Int?
  job          String? @db.NVarChar(200)
  phone        String? @db.VarChar(20)
  ethnicity    String? @db.NVarChar(50)
  religion     String? @db.NVarChar(50)
  nationality  String? @db.NVarChar(50)
  workplace    String? @db.NVarChar(255)
  position     String? @db.NVarChar(100)
  address      String? @db.NVarChar(500)
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TrainingScore {
  id             String   @id @default(uuid()) @db.VarChar(50)
  studentId      String   @db.VarChar(50)
  semesterId     String   @db.VarChar(50)
  score          Int
  classification String   @db.NVarChar(50)
  semester       Semester @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semesterId])
}

model Semester {
  id                String          @id @default(uuid()) @db.VarChar(50)
  code              String          @unique @db.VarChar(50)
  name              String          @db.NVarChar(255)
  year              Int             @default(2024)
  startDate         DateTime        @db.Date
  endDate           DateTime        @db.Date
  isCurrent         Boolean         @default(false)
  isRegistering     Boolean         @default(false)
  registerStartDate DateTime?
  registerEndDate   DateTime?
  classes           CourseClass[]
  studentFees       StudentFee[]
  trainingScores    TrainingScore[]
}

model Room {
  id        String          @id @default(uuid()) @db.VarChar(50)
  name      String          @unique @db.VarChar(100)
  building  String?         @db.VarChar(100)
  capacity  Int             @default(50)
  type      String          @default("THEORY") @db.VarChar(50)
  campus    String?         @db.NVarChar(100)
  schedules ClassSchedule[]
}

model CourseClass {
  id                String          @id @default(uuid()) @db.VarChar(50)
  subjectId         String          @db.VarChar(50)
  semesterId        String          @db.VarChar(50)
  lecturerId        String?         @db.VarChar(50)
  code              String          @unique @db.VarChar(50)
  name              String          @db.NVarChar(255)
  tuitionMultiplier Float           @default(1.0)
  maxSlots          Int             @default(60)
  currentSlots      Int             @default(0)
  status            String          @default("OPEN") @db.VarChar(50)
  schedules         ClassSchedule[]
  lecturer          Lecturer?       @relation(fields: [lecturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  semester          Semester        @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  subject           Subject         @relation(fields: [subjectId], references: [id], onUpdate: NoAction)
  enrollments       Enrollment[]
  grades            Grade[]
  adminClasses      AdminClass[]    @relation("AdminClassToCourseClass")
}

model ClassSchedule {
  id            String      @id @default(uuid()) @db.VarChar(50)
  courseClassId String      @db.VarChar(50)
  roomId        String?     @db.VarChar(50)
  semesterId    String      @db.VarChar(50)
  dayOfWeek     Int
  startShift    Int
  endShift      Int
  type          String      @db.VarChar(50)
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  room          Room?       @relation(fields: [roomId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomId, dayOfWeek, startShift, semesterId])
}

model Enrollment {
  id            String       @id @default(uuid()) @db.VarChar(50)
  studentId     String       @db.VarChar(50)
  courseClassId String       @db.VarChar(50)
  status        String       @default("REGISTERED") @db.VarChar(50)
  registeredAt  DateTime     @default(now())
  isRetake      Boolean      @default(false)
  tuitionFee    Decimal      @default(0) @db.Decimal(10, 2)
  attendances   Attendance[]
  courseClass   CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([studentId, courseClassId])
}

model Attendance {
  id           String     @id @default(uuid()) @db.VarChar(50)
  enrollmentId String     @db.VarChar(50)
  date         DateTime   @db.Date
  status       String     @default("PRESENT") @db.VarChar(50)
  note         String?    @db.NVarChar(255)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, date])
}

model Grade {
  id                String      @id @default(uuid()) @db.VarChar(50)
  studentId         String      @db.VarChar(50)
  courseClassId     String      @db.VarChar(50)
  subjectId         String      @db.VarChar(50)
  attendanceScore   Float?
  regularScore1     Float?
  regularScore2     Float?
  practiceScore     Float?
  midtermScore      Float?
  isEligibleForExam Boolean     @default(true)
  isAbsentFromExam  Boolean     @default(false)
  finalScore        Float?
  totalScore10      Float?
  totalScore4       Float?
  letterGrade       String?     @db.VarChar(10)
  isPassed          Boolean     @default(false)
  isLocked          Boolean     @default(false)
  status            String      @default("DRAFT") @db.VarChar(50)
  courseClass       CourseClass @relation(fields: [courseClassId], references: [id], onUpdate: NoAction)
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subject           Subject     @relation(fields: [subjectId], references: [id], onUpdate: NoAction)

  @@unique([studentId, subjectId, courseClassId])
}

model TuitionConfig {
  id             String  @id @default(uuid()) @db.VarChar(50)
  majorId        String  @db.VarChar(50)
  academicYear   Int
  pricePerCredit Decimal @db.Decimal(12, 2)
}

model StudentFee {
  id             String           @id @default(uuid()) @db.VarChar(50)
  studentId      String           @db.VarChar(50)
  semesterId     String           @db.VarChar(50)
  feeType        String           @db.VarChar(50)
  name           String           @db.NVarChar(255)
  isMandatory    Boolean          @default(true)
  totalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @default(0) @db.Decimal(12, 2)
  status         String           @default("DEBT") @db.VarChar(50)
  dueDate        DateTime?        @db.Date
  transactions   FeeTransaction[]
  semester       Semester         @relation(fields: [semesterId], references: [id], onUpdate: NoAction)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model FeeTransaction {
  id              String     @id @default(uuid()) @db.VarChar(50)
  studentFeeId    String     @db.VarChar(50)
  amount          Decimal    @db.Decimal(12, 2)
  transactionType String     @default("PAYMENT") @db.VarChar(50)
  paymentMethod   String     @db.VarChar(50)
  transactionDate DateTime   @default(now())
  transactionCode String?    @db.VarChar(100)
  studentFee      StudentFee @relation(fields: [studentFeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
