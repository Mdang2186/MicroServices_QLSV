model ExamPlan {
  id                String   @id @default(uuid()) @db.VarChar(50)
  semesterId        String   @db.VarChar(50)
  subjectId         String   @db.VarChar(50)
  cohort            String   @db.VarChar(50)
  examDate          DateTime @db.Date
  startShift        Int
  endShift          Int
  examType          String   @db.VarChar(50)
  examForm          String?  @db.NVarChar(100)
  preferredRoomType String?  @db.VarChar(50)
  venueMode         String   @default("AUTO") @db.VarChar(50)
  note              String?  @db.NVarChar(500)
  totalStudents     Int      @default(0)
  totalRooms        Int      @default(0)
  status            String   @default("SCHEDULED") @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@unique([semesterId, subjectId, cohort, examDate, startShift])
  @@index([semesterId, examDate])
  @@index([subjectId, cohort])
}

model ExamRoomAssignment {
  id            String   @id @default(uuid()) @db.VarChar(50)
  examPlanId    String   @db.VarChar(50)
  roomId        String?  @db.VarChar(50)
  roomName      String   @db.NVarChar(255)
  roomType      String?  @db.VarChar(50)
  building      String?  @db.NVarChar(100)
  capacity      Int
  assignedCount Int      @default(0)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([examPlanId, sortOrder])
  @@index([roomId])
}

model ExamStudentAssignment {
  id               String   @id @default(uuid()) @db.VarChar(50)
  examPlanId       String   @db.VarChar(50)
  roomAssignmentId String   @db.VarChar(50)
  gradeId          String   @unique @db.VarChar(50)
  studentId        String   @db.VarChar(50)
  courseClassId    String   @db.VarChar(50)
  studentCode      String   @db.VarChar(50)
  studentName      String   @db.NVarChar(255)
  adminClassCode   String?  @db.VarChar(50)
  examSbd          String   @db.VarChar(50)
  seatNumber       Int
  createdAt        DateTime @default(now())

  @@unique([examPlanId, examSbd])
  @@unique([roomAssignmentId, seatNumber])
  @@index([examPlanId, studentId])
  @@index([courseClassId])
}
